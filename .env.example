# 英文品牌名, 例如 emos / emya / emotion
APP_NAME=emotion
# 日志级别 debug / info / warn / error
APP_LOG_LEVEL=info

# 服务相关
## 监听地址
SERVER_HOST=0.0.0.0
## 监听端口
SERVER_PORT=8096

# 数据库相关
## 数据库驱动 postgres
DB_DRIVER=postgres
## 数据库地址
DB_HOST=127.0.0.1
## 数据库端口
DB_PORT=5432
## 数据库名
DB_DATABASE=emotion
## 数据库用户名
DB_USERNAME=emotion
## 数据库密码
DB_PASSWORD=emotion_pwd
## 连接池大小
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME_MINUTES=30

# redis / valkey 缓存 可选
## 留空则使用内存缓存
VALKEY_HOST=
VALKEY_PORT=6379
VALKEY_USERNAME=
VALKEY_PASSWORD=

# api 相关
## 管理 API Key 用于 Sakura_embyboss 等管理端调用
API_KEY=change-me-please
## 管理后台登录账号；仅首次没有后台账号时用于初始化
ADMIN_USERNAME=admin
## 管理后台登录密码；仅首次没有后台账号时用于初始化
ADMIN_PASSWORD=change-me-please
## 外部接口地址 末尾不带 / 用于触发 userLogin / userSearch / userFavorite / videoGetUrl / subtitleGetUrl
## 例如 http://127.0.0.1:8000/emya
## 留空即关闭外部接口
API_EXTERNAL=

# 其他
## 默认搜索展示内容 json 格式 key为名称 value为 video_list 表中id
SEARCH_DEFAULT_LIST={"欢迎来到emotion":1}

# emby 服务元信息
EMBY_VERSION=4.8.10.0
EMBY_ID=emotion

# emby 其他服务器地址 https://github.com/uhdnow/emby_ext_domains
EMBY_EXT_SERVER_DOMAINS=

# TMDB 元数据
## v3 API key (32 位 hex) 或 v4 bearer token (eyJ 开头) 任选其一
## 不填 = 关闭 TMDB 刮削
TMDB_API_KEY=
## 刮削语言 默认中文
TMDB_LANGUAGE=zh-CN
## 扫描时是否自动刮削新入库的条目 true/false
TMDB_AUTO_SCRAPE=true
## TheTVDB v4 保底刮削，主要用于剧集；不填则关闭
TVDB_API_KEY=
## TheTVDB PIN 可选
TVDB_PIN=
## OMDb 保底刮削，主要用于 IMDb ID / 电影基础信息；不填则关闭
OMDB_API_KEY=
