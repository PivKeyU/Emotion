# 英文品牌名 如 emos / emya / next-emby
APP_NAME=next-emby
# 授权人数 默认10人
APP_AUTH_NUMBER=10
# 日志级别 debug / info / warn / error
APP_LOG_LEVEL=info

# 服务相关
## 监听地址
SERVER_HOST=0.0.0.0
## 监听端口
SERVER_PORT=8096

# 数据库相关
## 数据库驱动 mysql
DB_DRIVER=mysql
## 数据库地址
DB_HOST=127.0.0.1
## 数据库端口
DB_PORT=3306
## 数据库名
DB_DATABASE=next_emby
## 数据库用户名
DB_USERNAME=root
## 数据库密码
DB_PASSWORD=
## 连接池大小
DB_MAX_OPEN_CONNS=20

# redis / valkey 缓存 可选
## 留空则使用内存缓存
VALKEY_HOST=
VALKEY_PORT=6379
VALKEY_USERNAME=
VALKEY_PASSWORD=

# api 相关
## 管理 API Key 用于 Sakura_embyboss 等管理端调用
API_KEY=changeme
## 外部接口地址 末尾不带/ 用于触发 userLogin / userSearch / userFavorite / videoGetUrl / subtitleGetUrl
## 例: http://127.0.0.1:8000/emya
## 留空即关闭外部接口
API_EXTERNAL=

# 其他
## 默认搜索展示内容 json 格式 key为名称 value为 video_list 表中id
SEARCH_DEFAULT_LIST={"欢迎来到next-emby":1}

# emby 服务元信息
EMBY_VERSION=4.8.10.0
EMBY_ID=next-emby

# emby 其他服务器地址 https://github.com/uhdnow/emby_ext_domains
EMBY_EXT_SERVER_DOMAINS=
